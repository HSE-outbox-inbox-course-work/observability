{
  "uid": "outbox-service",
  "title": "Outbox Service",
  "tags": ["course-work", "outbox"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP (RED)",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request rate by status",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 1, "w": 8, "h": 7},
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "stacking": {"mode": "normal"}}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "sum by (status) (rate(outbox_http_requests_total[1m]))", "legendFormat": "{{status}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Error ratio (4xx + 5xx)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 8, "y": 1, "w": 8, "h": 7},
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "sum by (route) (rate(outbox_http_requests_total{status=~\"4..|5..\"}[5m])) / clamp_min(sum by (route) (rate(outbox_http_requests_total[5m])),0.001)", "legendFormat": "{{route}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP latency p50/p95/p99",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 16, "y": 1, "w": 8, "h": 7},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 5}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.50, sum by (le, route) (rate(outbox_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{route}}", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le, route) (rate(outbox_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{route}}", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "C", "expr": "outbox:http_latency:p99_5m", "legendFormat": "p99 {{route}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },

    {
      "id": 2,
      "type": "row",
      "title": "Business: money transfers",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Transfer attempts by outcome",
      "description": "Terminal-исход usecase TransferMoney: ok / insufficient_funds / invalid_amount / account_not_found / db_error.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 9, "w": 12, "h": 8},
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "stacking": {"mode": "normal"}}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "sum by (outcome) (rate(outbox_transfer_attempts_total[1m]))", "legendFormat": "{{outcome}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Transfer duration p50/p95/p99",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 9, "w": 12, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 5}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(outbox_transfer_duration_seconds_bucket[5m])))", "legendFormat": "p50", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(outbox_transfer_duration_seconds_bucket[5m])))", "legendFormat": "p95", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(outbox_transfer_duration_seconds_bucket[5m])))", "legendFormat": "p99", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },

    {
      "id": 3,
      "type": "row",
      "title": "Outbox table",
      "gridPos": {"x": 0, "y": 17, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Events inserted / s",
      "description": "Сколько событий accounts.money.transferred реально записано в outbox после COMMIT.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 18, "w": 12, "h": 7},
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "sum by (event_type) (rate(outbox_events_inserted_total[1m]))", "legendFormat": "{{event_type}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Replication slot WAL lag (bytes)",
      "description": "Размер WAL, который ещё держит slot outbox_slot — недоставленный Debezium-ом объём.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 18, "w": 12, "h": 7},
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "pg_replication_slots_pg_wal_lsn_diff", "legendFormat": "{{slot_name}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },

    {
      "id": 4,
      "type": "row",
      "title": "pgxpool & runtime",
      "gridPos": {"x": 0, "y": 25, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "pgxpool connections",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 26, "w": 12, "h": 7},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "outbox_pgx_pool_acquired_connections", "legendFormat": "acquired", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "B", "expr": "outbox_pgx_pool_idle_connections", "legendFormat": "idle", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "C", "expr": "outbox_pgx_pool_total_connections", "legendFormat": "total", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "D", "expr": "outbox_pgx_pool_max_connections", "legendFormat": "max", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "pgxpool wait count",
      "description": "Кумулятивное число Acquire-вызовов, которым пришлось ждать свободного соединения.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 26, "w": 12, "h": 7},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {"refId": "A", "expr": "outbox_pgx_pool_wait_count", "legendFormat": "wait_count", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Goroutines & heap",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 33, "w": 12, "h": 7},
      "fieldConfig": {
        "defaults": {"custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 5}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "heap"}, "properties": [{"id": "unit", "value": "bytes"}, {"id": "custom.axisPlacement", "value": "right"}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "go_goroutines{job=\"outbox\"}", "legendFormat": "goroutines", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "B", "expr": "go_memstats_heap_inuse_bytes{job=\"outbox\"}", "legendFormat": "heap", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "Postgres outbox table (dead/live tuples)",
      "description": "pg_stat_user_tables по таблице outbox.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 33, "w": 12, "h": 7},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "pg_stat_user_tables_n_dead_tup{relname=\"outbox\"}", "legendFormat": "dead", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "B", "expr": "pg_stat_user_tables_n_live_tup{relname=\"outbox\"}", "legendFormat": "live", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    }
  ]
}
